root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
tab_width = 4
trim_trailing_whitespace = true

[.gitignore]
insert_final_newline = false

[*.md]
indent_size = 2
indent_style = space
trim_trailing_whitespace = false

[*.{pl,t,pm}]
indent_size = 4
indent_style = space
tab_width = 4
